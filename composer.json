{
    "name": "fedale/authorization-token-bundle",
    "description": "Persistence-agnostic infrastructure for temporary authorization tokens in Symfony.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "bundle", "token", "authorization", "ddd"],
    "authors": [
        {
            "name": "Danilo Di Moia",
            "email": "zitter@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "psr/clock": "^1.0",
        "psr/event-dispatcher": "^1.0",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/yaml": "^6.4 || ^7.0"
    },
    "require-dev": {
        "doctrine/dbal": "^3.6 || ^4.0",
        "doctrine/orm": "^2.14 || ^3.0",
        "doctrine/persistence": "^3.1 || ^4.0",
        "phpunit/phpunit": "^10.5",
        "symfony/cache": "^6.4 || ^7.0",
        "symfony/event-dispatcher": "^6.4 || ^7.0"
    },
    "suggest": {
        "doctrine/orm": "Enables the built-in Doctrine storage adapter, auto-registered when DoctrineBundle is present."
    },
    "autoload": {
        "psr-4": {
            "Fedale\\AuthorizationTokenBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fedale\\AuthorizationTokenBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
